{
  "name": "agent-idl",
  "version": "1.0.0",
  "description": "AgentIDL: A bridge between semantic and execution for agents",
  "main": "dist/sdk/agent-sdk.ts",
  "scripts": {
    "build": "tsc",
    "test": "echo \"Error: no test specified\" && exit 1",
    "test:conformance": "node agent-idl-tests/agent-idl-test.js",
    "generate:agenttask": "node dist/compiler/generator.js",
    "generate:browserai": "node dist/compiler/generator.js --idl idl/browser-ai.idl --jsonld idl/generated/browser-ai.jsonld --ttl idl/generated/browser-ai.ttl"
  },
  "keywords": [
    "agent",
    "idl",
    "webidl",
    "semantic",
    "ontology"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "webidl2": "^24.5.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/webidl2": "^24.4.3",
    "typescript": "^5.0.0"
  }
}
